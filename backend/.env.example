# Clé API Cerebras (modèle gpt-oss-120b) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Port HTTP (défaut 8787 en dev, 3000 conseillé en prod Coolify)
# PORT=8787

# PostHog — observabilité LLM ($ai_generation sur chaque appel Cerebras) + events
# produit (classify_batch, feed_served). Projet EU PARTAGÉ : les produits sont
# distingués par la super-property product:'spoilguard'.
# Laisser POSTHOG_API_KEY vide désactive tout proprement (no-op, best-effort).
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
